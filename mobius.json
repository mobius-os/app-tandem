  "theme_color": "#0c0f14",
  "background_color": "#0c0f14",
  "permissions": {
    "cross_app_access": "none",
    "share_with_apps": "none"
  },
  "storage_seeds": {
    "system-prompt.md": "system-prompt.md"
  },
  "schedule": {
    "job": "generate.sh"
  },
